{
  "name": "universal-icm-connector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generic connector that extracts compensation rule concepts from any ICM system and normalizes them into a vendor-agnostic schema",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "concurrently -n api,dash -c blue,green \"npm run dev:api\" \"npm run dev:dashboard\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:dashboard": "cd dashboard && npm run dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "extract": "tsx src/cli.ts extract",
    "dashboard": "tsx src/server.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "^0.19.10",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "hono": "^4.12.8",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.37",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
