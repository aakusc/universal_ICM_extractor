# Universal ICM Connector — Environment Variables
# Copy this file to .env and fill in values

# ─── AI Provider (Rule Interpretation) ───────────────────────
# Priority: AICR Gateway > Claude direct > OpenAI fallback
ANTHROPIC_API_KEY=
AICR_GATEWAY_URL=
AICR_API_KEY=
OPENAI_API_KEY=

# Optional model overrides
CLAUDE_MODEL=claude-sonnet-4-6
GATEWAY_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# ─── Varicent ────────────────────────────────────────────────
VARICENT_BASE_URL=
VARICENT_CLIENT_ID=
VARICENT_CLIENT_SECRET=

# ─── Xactly ─────────────────────────────────────────────────
XACTLY_BASE_URL=
XACTLY_API_KEY=
XACTLY_API_SECRET=

# ─── SAP SuccessFactors ICM ─────────────────────────────────
SAP_SF_BASE_URL=
SAP_SF_CLIENT_ID=
SAP_SF_CLIENT_SECRET=

# ─── CaptivateIQ ───────────────────────────────────────────
# Generate token in CaptivateIQ → User Profile → API Tokens
CAPTIVATEIQ_API_TOKEN=

# ─── Salesforce / Spiff ─────────────────────────────────────
SALESFORCE_BASE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
